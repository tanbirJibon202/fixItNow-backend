DATABASE_URL="YOUR_CONNECTION_STRING_HERE"
PORT=5000
APP_URL="http://localhost:5000"
BCRYPT_SALT_ROUNDS=10
JWT_ACCESS_SECRET="YOUR_ACCESS_SECRET_HERE"
JWT_ACCESS_EXPIRES_IN="1d"
JWT_REFRESH_SECRET="YOUR_REFRESH_SECRET_HERE"
JWT_REFRESH_EXPIRES_IN="30d"

STRIPE_SECRET_KEY="YOUR_STRIPE_SECRET_KEY"
STRIPE_WEBHOOK_SECRET="YOUR_STRIPE_WEBHOOK_SECRET"

# Credentials used by `npm run seed` to create demo accounts.
# Set your own values here for a private deploy; if left unset, seed.ts falls
# back to public demo defaults (admin@fixitnow.com / Admin@123, etc.).
SEED_ADMIN_EMAIL="YOUR_SEED_ADMIN_EMAIL"
SEED_ADMIN_PASSWORD="YOUR_SEED_ADMIN_PASSWORD"
SEED_TECHNICIAN_EMAIL="YOUR_SEED_TECHNICIAN_EMAIL"
SEED_TECHNICIAN_PASSWORD="YOUR_SEED_TECHNICIAN_PASSWORD"
SEED_CUSTOMER_EMAIL="YOUR_SEED_CUSTOMER_EMAIL"
SEED_CUSTOMER_PASSWORD="YOUR_SEED_CUSTOMER_PASSWORD"
